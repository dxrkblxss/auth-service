{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Jwt": {
        "Issuer": "AuthService",
        "Audience": "AuthClient",
        "AccessTokenMinutes": 15
    },
    "RefreshTokenSettings": {
        "DaysValid": 7,
        "TokenLengthBytes": 64
    },
    "Hashing": {
        "MemorySize": 65536,
        "Iterations": 3,
        "DegreeOfParallelism": 4
    },
    "Redis": {
        "Connection": "redis:6379"
    }
}